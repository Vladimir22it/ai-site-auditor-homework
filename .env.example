# Выберите провайдера: proxyapi, routerai, kodikrouter или custom.
LLM_PROVIDER=custom

# Безопасное значение-пример. Замените локально или в Streamlit Secrets; не коммитьте реальные ключи.
LLM_API_KEY=your-api-key-here

# Для proxyapi/routerai/kodikrouter base_url можно оставить пустым: приложение подставит значение по LLM_PROVIDER.
# Для custom укажите URL OpenAI-compatible endpoint, например https://api.example.com/v1.
LLM_BASE_URL=

# Укажите модель, доступную у выбранного провайдера.
LLM_MODEL=your-model-name

# По умолчанию browser fallback отключён. Включите для JS-сайтов, если установлен Playwright и браузеры.
ENABLE_BROWSER_FETCH=false

# Ограничения crawler'а. Значения выше максимумов будут безопасно ограничены приложением.
HTTP_TIMEOUT_SECONDS=12
MAX_PAGES=5
MAX_INTERNAL_PAGES=4
MAX_PAGE_CHARS=10000
MAX_TOTAL_CHARS=40000
MIN_TEXT_CHARS_FOR_BROWSER_FALLBACK=500
